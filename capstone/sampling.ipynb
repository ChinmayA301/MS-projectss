import pandas as pd
import numpy as np
from tqdm import tqdm

EMR_PATH = "emr_raw.csv"
CHUNKSIZE = 500_000  # tune depending on RAM (100k–1M)

# Adjust these names if needed
COLS = [
    "PATIENT ID", "ENCOUNTER DATE", "RESULT DATETIME", "RESULT VALUE NUM", "RESULT UNIT",
    "AGE AT VISIT", "SEX", "ADI NATIONAL RANK 22", "RURAL COUNTY CODE DESCRIPTION"
]

def normalize_chunk(c):
    rename_map = {
        "PATIENT ID": "patient_id",
        "ENCOUNTER DATE": "encounter_date",
        "RESULT DATETIME": "result_datetime",
        "RESULT VALUE NUM": "hba1c_value",
        "RESULT UNIT": "result_unit",
        "AGE AT VISIT": "age",
        "SEX": "sex",
        "ADI NATIONAL RANK 22": "adi_natrank",
        "RURAL COUNTY CODE DESCRIPTION": "rural_desc",
    }
    c = c.rename(columns={k: v for k, v in rename_map.items() if k in c.columns})

    c["encounter_date"] = pd.to_datetime(c["encounter_date"], errors="coerce")
    if "result_datetime" in c.columns:
        c["result_datetime"] = pd.to_datetime(c["result_datetime"], errors="coerce")

    # If encounter_date missing, fill from result_datetime
    miss = c["encounter_date"].isna() & c["result_datetime"].notna()
    c.loc[miss, "encounter_date"] = c.loc[miss, "result_datetime"]

    c["hba1c_value"] = pd.to_numeric(c["hba1c_value"], errors="coerce")
    c["adi_natrank"] = pd.to_numeric(c["adi_natrank"], errors="coerce")
    c["age"] = pd.to_numeric(c["age"], errors="coerce")

    c["sex"] = c["sex"].astype(str).str.upper()
    c.loc[~c["sex"].isin(["M","F"]), "sex"] = "OTHER"

    c["rural_flag"] = np.where(
        c["rural_desc"].astype(str).str.contains("Rural", case=False, na=False),
        1, 0
    )

    # Outcome flag
    c["uncontrolled"] = (c["hba1c_value"] > 7.0).astype(int)
    return c

# patient_index: one row per patient with summary stats
patient_index = {}

reader = pd.read_csv(EMR_PATH, usecols=lambda x: x in COLS, chunksize=CHUNKSIZE)

for chunk in tqdm(reader, desc="Pass 1: building patient index"):
    chunk = normalize_chunk(chunk)
    chunk = chunk.dropna(subset=["patient_id", "encounter_date", "hba1c_value", "adi_natrank"])
    chunk = chunk[chunk["age"] >= 18]

    # For each patient within chunk, update summary
    for pid, g in chunk.groupby("patient_id"):
        # earliest uncontrolled date in this chunk
        uc_dates = g.loc[g["uncontrolled"] == 1, "encounter_date"]
        chunk_t0 = uc_dates.min() if not uc_dates.empty else pd.NaT

        # Update patient record
        if pid not in patient_index:
            patient_index[pid] = {
                "patient_id": pid,
                "sex": g["sex"].iloc[0],
                "age": g["age"].iloc[0],
                "adi_natrank": g["adi_natrank"].iloc[0],
                "rural_flag": g["rural_flag"].iloc[0],
                "t0": chunk_t0
            }
        else:
            # update t0 if earlier found
            if pd.notna(chunk_t0):
                old_t0 = patient_index[pid]["t0"]
                if pd.isna(old_t0) or chunk_t0 < old_t0:
                    patient_index[pid]["t0"] = chunk_t0

# Convert to DataFrame
patient_df = pd.DataFrame(list(patient_index.values()))
patient_df = patient_df.dropna(subset=["adi_natrank"])  # must have ADI
patient_df["adi_quintile"] = pd.qcut(patient_df["adi_natrank"], 5, labels=False, duplicates="drop") + 1
patient_df["t0_year"] = pd.to_datetime(patient_df["t0"], errors="coerce").dt.year

print("Patients in index:", len(patient_df))
print(patient_df.head())

N_TARGET = 20000
strat_cols = ["adi_quintile", "sex", "t0_year", "rural_flag"]

# You can either keep all patients with a valid t0, or include those without t0 (depends on design).
patient_df_valid = patient_df.dropna(subset=["t0_year"]).copy()

stratum_counts = (
    patient_df_valid.groupby(strat_cols).size().reset_index(name="N_full")
)
total_full = stratum_counts["N_full"].sum()
stratum_counts["prop_full"] = stratum_counts["N_full"] / total_full
stratum_counts["N_sample"] = (stratum_counts["prop_full"] * N_TARGET).round().astype(int)
stratum_counts.loc[(stratum_counts["N_full"] > 0) & (stratum_counts["N_sample"] == 0), "N_sample"] = 1

patient_df_valid = patient_df_valid.merge(stratum_counts, on=strat_cols, how="left")

sampled_ids = []
for _, row in stratum_counts.iterrows():
    mask = (
        (patient_df_valid["adi_quintile"] == row["adi_quintile"]) &
        (patient_df_valid["sex"] == row["sex"]) &
        (patient_df_valid["t0_year"] == row["t0_year"]) &
        (patient_df_valid["rural_flag"] == row["rural_flag"])
    )
    strata = patient_df_valid[mask]
    n = int(row["N_sample"])
    if len(strata) <= n:
        sampled_ids.extend(strata["patient_id"].tolist())
    else:
        sampled_ids.extend(strata.sample(n=n, random_state=42)["patient_id"].tolist())

sampled_ids = set(sampled_ids)
print("Sampled patients:", len(sampled_ids))

import pyarrow as pa
import pyarrow.parquet as pq

OUT_PARQUET = "emr_sample.parquet"

writer = None
reader = pd.read_csv(EMR_PATH, chunksize=CHUNKSIZE)

for chunk in tqdm(reader, desc="Pass 2: extracting sampled rows"):
    chunk = normalize_chunk(chunk)
    chunk = chunk[chunk["patient_id"].isin(sampled_ids)]
    if chunk.empty:
        continue

    table = pa.Table.from_pandas(chunk, preserve_index=False)
    if writer is None:
        writer = pq.ParquetWriter(OUT_PARQUET, table.schema)
    writer.write_table(table)

if writer:
    writer.close()

print("Saved sampled dataset:", OUT_PARQUET)



import pandas as pd
import numpy as np
from scipy.stats import ks_2samp, chi2_contingency

def standardized_mean_difference(x_full, x_samp):
    """
    Compute standardized mean difference (SMD)
    """
    mean_f, mean_s = np.nanmean(x_full), np.nanmean(x_samp)
    var_f, var_s = np.nanvar(x_full, ddof=1), np.nanvar(x_samp, ddof=1)
    pooled_sd = np.sqrt((var_f + var_s) / 2)
    if pooled_sd == 0:
        return 0.0
    return (mean_s - mean_f) / pooled_sd

def numeric_balance_table(full_df, samp_df, variables):
    rows = []

    for v in variables:
        xf = full_df[v].dropna()
        xs = samp_df[v].dropna()

        if len(xf) == 0 or len(xs) == 0:
            continue

        smd = standardized_mean_difference(xf, xs)
        ks_stat, ks_p = ks_2samp(xf, xs)

        rows.append({
            "variable": v,
            "type": "numeric",
            "full_mean": xf.mean(),
            "sample_mean": xs.mean(),
            "full_sd": xf.std(),
            "sample_sd": xs.std(),
            "SMD": smd,
            "KS_stat": ks_stat,
            "KS_pvalue": ks_p
        })

    return pd.DataFrame(rows)

def categorical_balance_table(full_df, samp_df, variables):
    rows = []

    for v in variables:
        full_counts = full_df[v].value_counts(normalize=True)
        samp_counts = samp_df[v].value_counts(normalize=True)

        cats = sorted(set(full_counts.index).union(set(samp_counts.index)))

        # Build contingency table for chi-square
        contingency = []
        for c in cats:
            contingency.append([
                full_df[v].value_counts().get(c, 0),
                samp_df[v].value_counts().get(c, 0)
            ])
        contingency = np.array(contingency)

        try:
            chi2, p, _, _ = chi2_contingency(contingency)
        except Exception:
            chi2, p = np.nan, np.nan

        for c in cats:
            rows.append({
                "variable": v,
                "category": c,
                "type": "categorical",
                "full_prop": full_counts.get(c, 0),
                "sample_prop": samp_counts.get(c, 0),
                "abs_prop_diff": abs(
                    full_counts.get(c, 0) - samp_counts.get(c, 0)
                ),
                "chi2_pvalue": p
            })

    return pd.DataFrame(rows)

# Define variables to test
NUMERIC_VARS = ["age", "adi_natrank"]
CATEGORICAL_VARS = ["sex", "adi_quintile", "rural_flag", "t0_year"]

